# Python
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Program Created Artifact Directories
# Ignore generated files in these output folders but keep the folders tracked
/transcripts/*
!/transcripts/.gitkeep
/summaries/*
!/summaries/.gitkeep
/previous_run_results/*
!/previous_run_results/.gitkeep
*.wav
.DS_Store

# Processed/archived wav files moved by batch_run.sh; ignore their contents
/transcribed_wav/*

# Explicitly ignore the archive subfolder as well (keeps intent clear)
/transcribed_wav/archive/
/vertex_intro_class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
*.egg

# Virtual environments
venv/
ENV/
env/
.env/
.venv/
venv.bak/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
hypothesis/
test-results/

# Translations
*.mo

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code
#   is intended to run in multiple environments; otherwise, consider checking them in.
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# Environments
env/
venv/
ENV/
env.bak/

# mypy
.mypy_cache/

# Pyre
.pyre/

# Coverage reports
htmlcov/

# NOTE: This repo intentionally includes project editor settings under
# `.vscode/` and `.idea/` so do NOT ignore those directories here.
# If you normally use a global gitignore that includes .vscode or .idea,
# make sure to commit those project setting files for this project.
.env
.DS_Store
*.wav
*.mp3
*.m4a
*.flac
*.aac

# Downloaded or archived audio/video
downloads/
downloads/*
audio_archive/
audio_archive/*
